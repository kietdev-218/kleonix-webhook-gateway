HTTP_PORT=3000
LOG_LEVEL=info
RABBITMQ_URL=amqp://kleonix:change_this_to_a_secure_password@host.docker.internal:5672/
RABBITMQ_EXCHANGE=your_exchange_name
RABBITMQ_ROUTING_KEY=your_routing_key
WEBHOOK_SECRET=my-super-secret

# Advanced Configurations (Optional)
# REQUEST_TIMEOUT=10s
# MAX_REQUEST_SIZE=1048576
# RABMQ_MAX_RETRIES=5
# RABMQ_RETRY_DELAY=500ms
